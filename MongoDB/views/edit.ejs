<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Chat</title>
</head>
<body>
    <h2>Edit your chat!</h2>
    <p>This chat is send by <b><%=chat.from%></b> to <b><%=chat.to%></b></p>
    <form method="POST" action="/chats/<%=chat._id%>?_method=PUT">
        <textarea name="msg" rows="7" cols="50" ><%=chat.msg%></textarea>
        <br><br> 
        <button>Submit</button>
    </form>
</body>
</html>