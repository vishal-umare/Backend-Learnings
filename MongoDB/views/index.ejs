<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Whatsapp</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1>All Chats</h1>
    
    <form method="get" action="/chats/new">
        <button class="btn">New Chat</button>
    </form>

    <% for (let chat of chats){ %>
        <div class="chat">
            <p>From: <b> <%= chat.from %> </b></p>
            <div class="msg">
                <p><%= chat.msg %></p>
                <form action="/chats/<%=chat._id%>/edit" method="get">
                    <button>Edit</button>
                </form>
                <form action="/chats/<%=chat._id%>?_method=DELETE" method="post">
                    <button>Delete</button>
                </form>
            </div>          
            <p>Received by: <b><%= chat.to %></b></p>
            <hr>
            <p><%= chat.created_at.toString().split(" ") [4] %></p>
            <p><%= chat.created_at.toString().split(" ").slice(0, 4).join(" ") %></p>
        </div>
    <% } %>
</body>
</html>

